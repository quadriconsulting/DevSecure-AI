{
  "name": "devsecure-ai",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3001",
    "dev:devsecure": "wrangler pages dev dist --ip 0.0.0.0 --port 3001 --config wrangler.devsecure.json",
    "dev:jq": "wrangler pages dev dist --ip 0.0.0.0 --port 3001 --config wrangler.jq.json",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy:devsecure": "npm run build && wrangler pages deploy ./dist --project-name devsecure-ai --config wrangler.devsecure.json",
    "deploy:jq": "npm run build && wrangler pages deploy ./dist --project-name jq-tcr --config wrangler.jq.json",
    "deploy:jquadri": "npm run build && wrangler pages deploy ./dist --project-name jquadri-fit --config wrangler.jquadri.json",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3001/tcp 2>/dev/null || true"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "gsap": "^3.14.2",
    "hono": "^4.12.2",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.13.0",
    "openai": "^6.29.0",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^3.4.19",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
